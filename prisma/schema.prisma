generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── ENUMS ────────────────────────────────────────────

enum RoleType {
  SUPER_ADMIN
  ADMIN_AREA
  SUPERVISOR
  OPERARIO
  AUDITOR
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  BLOCKED
  AWAITING_REVIEW
  APPROVED
  REJECTED
  COMPLETED
  CANCELLED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum NotificationType {
  TASK_ASSIGNED
  TASK_APPROVED
  TASK_REJECTED
  TASK_DUE_SOON
  TASK_OVERDUE
  APPROVAL_REQUESTED
  COMMENT_MENTION
  STOCK_ALERT
}

// ─── MODELS ───────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  passwordHash  String
  avatar        String?
  phone         String?
  role          RoleType
  areaId        String?
  departmentId  String?
  area          Area?     @relation(fields: [areaId], references: [id])
  department    Department? @relation(fields: [departmentId], references: [id])
  tasksAssigned Task[]    @relation("AssignedTo")
  tasksCreated  Task[]    @relation("CreatedBy")
  taskComments  Comment[]
  taskLogs      TaskLog[]
  notifications Notification[]
  isActive      Boolean   @default(true)
  lastLoginAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  @@index([areaId])
  @@index([departmentId])
  @@index([role])
  @@index([email])
}

model Area {
  id          String       @id @default(cuid())
  name        String
  slug        String       @unique
  icon        String
  color       String
  description String?
  departments Department[]
  users       User[]
  tasks       Task[]
  kpis        AreaKPI[]
  createdAt   DateTime     @default(now())
}

model Department {
  id        String   @id @default(cuid())
  name      String
  slug      String
  areaId    String
  area      Area     @relation(fields: [areaId], references: [id], onDelete: Cascade)
  users     User[]
  tasks     Task[]
  createdAt DateTime @default(now())

  @@unique([slug, areaId])
  @@index([areaId])
}

model Task {
  id             String      @id @default(cuid())
  title          String
  description    String?     @db.Text
  priority       Priority    @default(MEDIUM)
  status         TaskStatus  @default(PENDING)
  dueDate        DateTime?
  completedAt    DateTime?
  estimatedHours Float?
  actualHours    Float?
  areaId         String
  departmentId   String?
  assignedToId   String?
  createdById    String
  parentTaskId   String?
  area           Area        @relation(fields: [areaId], references: [id])
  department     Department? @relation(fields: [departmentId], references: [id])
  assignedTo     User?       @relation("AssignedTo", fields: [assignedToId], references: [id])
  createdBy      User        @relation("CreatedBy", fields: [createdById], references: [id])
  parentTask     Task?       @relation("Subtasks", fields: [parentTaskId], references: [id])
  subtasks       Task[]      @relation("Subtasks")
  comments       Comment[]
  evidence       Evidence[]
  logs           TaskLog[]
  tags           Tag[]
  approvals      Approval[]
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  deletedAt      DateTime?

  @@index([areaId, status])
  @@index([assignedToId, status])
  @@index([dueDate])
  @@index([createdById])
  @@index([parentTaskId])
  @@index([status])
  @@index([priority])
}

model Approval {
  id          String         @id @default(cuid())
  taskId      String
  requestedBy String
  approvedBy  String?
  status      ApprovalStatus @default(PENDING)
  notes       String?        @db.Text
  requestedAt DateTime       @default(now())
  resolvedAt  DateTime?
  task        Task           @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([status])
  @@index([requestedBy])
}

model Evidence {
  id         String   @id @default(cuid())
  taskId     String
  uploadedBy String
  fileUrl    String
  fileType   String
  fileName   String
  fileSize   Int
  caption    String?
  task       Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@index([taskId])
}

model Comment {
  id        String   @id @default(cuid())
  taskId    String
  authorId  String
  content   String   @db.Text
  mentions  String[]
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  author    User     @relation(fields: [authorId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([taskId])
  @@index([authorId])
}

model TaskLog {
  id        String   @id @default(cuid())
  taskId    String
  userId    String
  action    String
  fromValue String?
  toValue   String?
  metadata  Json?
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@index([taskId])
  @@index([createdAt])
  @@index([userId])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String
  taskId    String?
  isRead    Boolean          @default(false)
  readAt    DateTime?
  user      User             @relation(fields: [userId], references: [id])
  createdAt DateTime         @default(now())

  @@index([userId, isRead])
  @@index([createdAt])
}

model AreaKPI {
  id         String   @id @default(cuid())
  areaId     String
  period     String
  totalTasks Int      @default(0)
  completed  Int      @default(0)
  overdue    Int      @default(0)
  avgHours   Float?
  area       Area     @relation(fields: [areaId], references: [id])
  updatedAt  DateTime @updatedAt

  @@unique([areaId, period])
  @@index([areaId])
  @@index([period])
}

model Tag {
  id    String @id @default(cuid())
  name  String @unique
  color String
  tasks Task[]
}
